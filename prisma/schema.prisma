generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model estoque_db {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(50)
  qtd_unidade   Decimal? @db.Decimal(5, 0)
  qtd_engradado Decimal? @db.Decimal(4, 0)
}
